CLERK_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENROUTER_API_KEY=

META_APP_ID=
META_APP_SECRET=

# ─── Phase 4 real-execution guards (single action: meta.pause_campaign) ───
# Default OFF. Even when ON, only orgs in META_LIVE_ORG_ALLOWLIST may trigger
# the real Meta API call (empty allowlist = all orgs allowed in dev mode).
# A real call is bracketed by `[exec] phase=exec.api_call/exec.api_response`
# log lines and always produces a decision_history row. The token is
# system-wide for now (Phase 2 will add per-org token storage).
META_PAUSE_CAMPAIGN_LIVE=false
META_DECREASE_BUDGET_LIVE=false
META_INCREASE_BUDGET_LIVE=false
# Hard server-side cap on per-call budget increase (in percent). Refuses any
# `percent > META_INCREASE_BUDGET_MAX_PERCENT` BEFORE contacting Meta. Default
# 50. Lower for tighter safety; raise (with caution) only after operator review.
META_INCREASE_BUDGET_MAX_PERCENT=50
META_TEST_ACCESS_TOKEN=
META_LIVE_ORG_ALLOWLIST=
META_GRAPH_VERSION=v18.0

# ─── Phase 4 real-execution guards (single action: send_alert_email) ──────
# Default OFF. Recipients are computed server-side from `users` (org admins
# only) — caller cannot override. Placeholder emails (@placeholder.local or
# @clerk.placeholder) are filtered out before any send. Idempotency is
# enforced upstream by execution_id, so retries do NOT produce duplicate
# emails. Reuses META_LIVE_ORG_ALLOWLIST as a generic live-exec allowlist.
SEND_ALERT_EMAIL_LIVE=false
RESEND_API_KEY=
ALERT_EMAIL_FROM=alerts@growthhub.local

GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

OAUTH_REDIRECT_BASE_URL=